---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Absolute path of this page, e.g. '/menu' — used for canonical URL */
  canonicalPath?: string;
  /** Absolute path to OG image, e.g. '/images/real-bulgogi.jpg' */
  ogImage?: string;
}

const {
  title = 'Sushi Kim 2 — Authentic Korean Food & Sushi · Downtown Pittsburgh',
  description = 'A 30+ year Pittsburgh institution serving authentic Korean home cooking and premium Japanese sushi at 110 Smithfield St, Downtown Pittsburgh.',
  canonicalPath = '',
  ogImage = '/images/real-bulgogi.jpg',
} = Astro.props;

// Update this when the production domain is confirmed
const SITE_URL = 'https://sushikim2.com';
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const ogImageUrl = `${SITE_URL}${ogImage}`;

const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  '@id': `${SITE_URL}/#restaurant`,
  name: 'Sushi Kim 2',
  alternateName: ['Sushi Kim 2 Downtown Pittsburgh', 'Sushi Kim Pittsburgh'],
  url: SITE_URL,
  telephone: '+14126001000',
  email: 'eatsushikim2@gmail.com',
  foundingDate: '1990',
  description:
    'A 30+ year Pittsburgh institution serving soulful Korean home cooking and premium Japanese sushi in the heart of downtown. Open since 1990 — first in the Strip District, now at 110 Smithfield Street, one block from Market Square.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '110 Smithfield St',
    addressLocality: 'Pittsburgh',
    addressRegion: 'PA',
    postalCode: '15222',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.4409,
    longitude: -79.9998,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Sunday',
      opens: '11:30',
      closes: '20:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '11:30',
      closes: '14:30',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '16:30',
      closes: '21:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '11:30',
      closes: '21:00',
    },
  ],
  servesCuisine: ['Korean', 'Japanese', 'Sushi', 'Korean BBQ', 'Sashimi', 'Asian'],
  priceRange: '$$',
  currenciesAccepted: 'USD',
  paymentAccepted: 'Cash, Credit Card',
  hasMenu: `${SITE_URL}/menu`,
  acceptsReservations: `${SITE_URL}/reservations`,
  menu: `${SITE_URL}/menu`,
  image: [
    `${SITE_URL}/images/real-bulgogi.jpg`,
    `${SITE_URL}/images/real-sushi-platter.jpg`,
    `${SITE_URL}/images/real-galbi.jpg`,
    `${SITE_URL}/images/real-bibimbop.jpg`,
  ],
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Takeout', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Dine-in', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Online Ordering', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Reservations', value: true },
  ],
  potentialAction: {
    '@type': 'ReserveAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE_URL}/reservations`,
      actionPlatform: [
        'http://schema.org/DesktopWebPlatform',
        'http://schema.org/MobileWebPlatform',
      ],
    },
    result: {
      '@type': 'Reservation',
      name: 'Table reservation at Sushi Kim 2',
    },
  },
  sameAs: [
    'https://www.facebook.com/sushikim2',
    'https://www.instagram.com/sushikim2',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: 'Sushi Kim 2',
  url: SITE_URL,
  description:
    'Official website of Sushi Kim 2 — authentic Korean food and Japanese sushi in Downtown Pittsburgh.',
  publisher: {
    '@id': `${SITE_URL}/#restaurant`,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE_URL}/menu?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Open Graph -->
    <meta property="og:type" content="restaurant" />
    <meta property="og:site_name" content="Sushi Kim 2" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sushi Kim 2 — Korean food and sushi in Downtown Pittsburgh" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Local business signals -->
    <meta name="geo.region" content="US-PA" />
    <meta name="geo.placename" content="Pittsburgh" />
    <meta name="geo.position" content="40.4409;-79.9998" />
    <meta name="ICBM" content="40.4409, -79.9998" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400&family=Noto+Serif+KR:wght@400;500;600&display=swap"
    />

    <!-- Global structured data: Restaurant + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Page-specific structured data slot -->
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
