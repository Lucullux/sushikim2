---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const pillars = [
  { n: '01', en: 'The food comes first.', desc: 'Every stew starts in the morning. Fish is cut by hand daily. We don\'t rush it.' },
  { n: '02', en: 'Fresh, every day.', desc: 'Fish arrives daily. Kimchi is fermented in-house. Banchan changes with the season.' },
  { n: '03', en: 'Consistent.', desc: 'The recipes haven\'t changed much in thirty years. That\'s the point.' },
];

const timeline = [
  { year: '1990', title: 'Doors open in the Strip District', body: 'Sushi Kim opens in Pittsburgh\'s Strip District with a Korean menu and a small sushi bar.' },
  { year: '2008', title: 'The galbi recipe is set', body: 'After years of iteration, the galbi marinade is finalized. It has not been changed since.' },
  { year: '2013', title: 'Second-generation chefs join the kitchen', body: 'The Kim children join the line, trained by their parents since childhood.' },
  { year: '2021', title: 'Sushi Kim 2 opens downtown', body: 'After COVID, we move to 110 Smithfield St. and reopen as Sushi Kim 2. The menu got shorter, but the favorites stayed.' },
  { year: '2023', title: '4.8 stars, 200+ reviews', body: 'Pittsburgh keeps coming back. We try to earn it every day.' },
  { year: '2026', title: '30+ years and counting', body: 'Still family-run. Still cooking slow. Still at 110 Smithfield.' },
];

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://sushikim2.com/about#webpage',
  name: 'Our Story — Sushi Kim 2',
  url: 'https://sushikim2.com/about',
  description:
    "The story of Sushi Kim 2 — a family-run Korean and Japanese restaurant in Downtown Pittsburgh open since 1990. From the Strip District to 110 Smithfield Street, over 30 years of authentic Korean cooking and fresh sushi.",
  isPartOf: { '@id': 'https://sushikim2.com/#website' },
  about: { '@id': 'https://sushikim2.com/#restaurant' },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: 'https://sushikim2.com/images/mr-kim.webp',
    caption: 'Mr. Kim, founder of Sushi Kim',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://sushikim2.com/#organization',
  name: 'Sushi Kim 2',
  url: 'https://sushikim2.com',
  foundingDate: '1990',
  foundingLocation: {
    '@type': 'Place',
    name: 'Strip District, Pittsburgh, PA',
  },
  description:
    'Family-run Korean and Japanese restaurant founded in 1990 in Pittsburgh\'s Strip District. Now located at 110 Smithfield St in Downtown Pittsburgh.',
  numberOfEmployees: {
    '@type': 'QuantitativeValue',
    minValue: 5,
    maxValue: 25,
  },
};
---

<Layout
  title="Our Story — Sushi Kim 2 · Downtown Pittsburgh"
  description="The story of Sushi Kim 2 — a family-run Korean and sushi restaurant in Downtown Pittsburgh, open since 1990. From the Strip District to 110 Smithfield Street."
  canonicalPath="/about"
  ogImage="/images/mr-kim.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </Fragment>
  <Nav />

  <main class="page">

    <!-- Hero -->
    <section class="px-pad" style="padding-top: 60px; padding-bottom: 100px;">
      <div class="max-w-site mx-auto">
        <p class="eyebrow" style="margin-bottom: 20px;">
          Our Story
        </p>
        <h1 class="display" style="max-width: 22ch;">
          Pittsburgh's Korean and Sushi restaurant <span class="it">since 1990.</span>
        </h1>
      </div>
    </section>

    <!-- Intro + image -->
    <section class="px-pad" style="margin-bottom: 120px;">
      <div class="max-w-site mx-auto">
        <div style="display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 80px; align-items: center;">

          <div style="aspect-ratio: 3/4; overflow: hidden;">
            <img src="/images/hanji.jpg" alt="Korean hanji paper texture — a nod to craft and tradition" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>

          <div>
            <p style="font-family: var(--serif); font-size: 32px; line-height: 1.35; color: var(--ink); font-weight: 400;">
              Sushi Kim opened in the Strip District in 1990. After more than two decades there,
              we moved to 110 Smithfield St. downtown after COVID and reopened as Sushi Kim 2.
            </p>
            <p class="body-lg" style="margin-top: 28px;">
              The menu got shorter, but the favorites stayed.
            </p>
            <p class="body-lg" style="margin-top: 20px;">
              Korean comfort food on one side, fresh-cut sushi on the other.
              That's always been the formula.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Pillars (dark) -->
    <section style="background: var(--ink); color: var(--cream); padding: 120px var(--pad);">
      <div class="max-w-site mx-auto">
        <p class="eyebrow" style="color: var(--gold-soft); margin-bottom: 24px;">
          How we cook
        </p>
        <h2 class="display" style="color: var(--cream); max-width: 18ch; margin-bottom: 72px;">
          Three things we <span class="it" style="color: var(--gold-soft);">don't compromise.</span>
        </h2>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px;">
          {pillars.map(p => (
            <div>
              <div class="mono" style="color: var(--gold-soft); margin-bottom: 20px;">{p.n}</div>
              <h3 class="display" style="color: var(--cream); font-size: 28px; margin-bottom: 14px;">
                <span class="it">{p.en}</span>
              </h3>
              <p style="color: rgba(245,239,227,0.7); font-size: 15px; line-height: 1.65;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="px-pad" style="padding-top: 120px; padding-bottom: 120px;">
      <div class="max-w-site mx-auto">
        <div style="display: grid; grid-template-columns: 1fr 1.6fr; gap: 80px;">

          <div class="timeline-header">
            <p class="eyebrow" style="margin-bottom: 20px;">Timeline</p>
            <h2 class="display">
              30+ years, <span class="it">in brief.</span>
            </h2>
          </div>

          <div>
            {timeline.map((ev, i) => (
              <div style={`
                display: grid; grid-template-columns: 120px 1fr; gap: 32px;
                padding: 28px 0;
                border-top: ${i === 0 ? '1px solid var(--line)' : 'none'};
                border-bottom: 1px solid var(--line);
              `}>
                <div style="font-family: var(--serif); font-size: 36px; font-style: italic; color: var(--red);">{ev.year}</div>
                <div>
                  <h3 style="font-family: var(--serif); font-size: 24px; margin-bottom: 8px;">{ev.title}</h3>
                  <p class="body" style="font-size: 15px;">{ev.body}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- Photo grid -->
    <section class="px-pad" style="padding-bottom: 120px;">
      <div class="max-w-site mx-auto">
        <div style="
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          grid-template-rows: 280px 280px;
          gap: 16px;
        ">
          <div style="grid-column: span 2; grid-row: span 2; overflow: hidden;">
            <img src="/images/dining.jpg" alt="Dining room at Sushi Kim 2" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
          <div style="overflow: hidden;">
            <img src="/images/sashimi.jpg" alt="Fresh sashimi" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
          <div style="overflow: hidden;">
            <img src="/images/galbi-tang.jpg" alt="Galbi Tang soup" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
          <div style="overflow: hidden;">
            <img src="/images/korean-spread.jpg" alt="Korean spread" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
          <div style="overflow: hidden;">
            <img src="/images/sushi-hand.jpg" alt="Chef preparing sushi" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
        </div>
      </div>
    </section>

    <!-- The soups -->
    <section class="px-pad" style="padding-top: 0; padding-bottom: 120px;">
      <div class="max-w-site mx-auto">
        <div style="border-top: 1px solid var(--line); padding-top: 80px; max-width: 720px;">
          <p class="eyebrow" style="margin-bottom: 20px;">The soups</p>
          <p style="font-family: var(--serif); font-size: clamp(24px, 3vw, 36px); line-height: 1.4; color: var(--ink); font-weight: 400;">
            Jjigae is at the center of the menu. Korean stew cooked low and slow —
            rich broth, bold flavor. It's the kind of food Pittsburgh winters were made for.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA (red) -->
    <section style="padding: 100px var(--pad); background: var(--red); color: var(--cream); text-align: center;">
      <p class="eyebrow" style="color: var(--gold-soft); margin-bottom: 20px;">Come eat with us</p>
      <h2 class="display" style="color: var(--cream); max-width: 28ch; margin: 0 auto 32px;">
        Korean comfort food and fresh-cut sushi <span class="it" style="color: var(--gold-soft);">in the heart of downtown Pittsburgh.</span>
      </h2>
      <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
        <a href="/reservations" class="btn btn-outline-cream">Reserve <span class="arr">→</span></a>
        <a href="/menu" class="btn btn-cream-on-red">View Menu</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .timeline-header {
    position: sticky;
    top: 120px;
    align-self: start;
  }

  @media (max-width: 900px) {
    .timeline-header {
      position: static !important;
    }
    div[style*="grid-template-columns: 0.9fr 1.1fr"],
    div[style*="grid-template-columns: 1fr 1.6fr"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns: repeat(3, 1fr)"] {
      grid-template-columns: 1fr 1fr !important;
    }
    div[style*="grid-template-columns: repeat(4, 1fr)"] {
      grid-template-columns: 1fr 1fr !important;
      grid-template-rows: auto !important;
    }
    div[style*="grid-column: span 2"] {
      grid-column: span 2 !important;
    }
  }
  @media (max-width: 600px) {
    div[style*="grid-template-columns: repeat(3, 1fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
