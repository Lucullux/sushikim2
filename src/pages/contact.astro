---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Sushi Kim 2 · Downtown Pittsburgh">
  <Nav />

  <main class="page">

    <section class="px-pad" style="padding-top: 60px; padding-bottom: 80px;">
      <div class="max-w-site mx-auto">

        <p class="eyebrow" style="margin-bottom: 20px;">
          Find us
        </p>
        <h1 class="display" style="max-width: 18ch; margin-bottom: 80px;">
          110 Smithfield St,<br/>
          <span class="it">Downtown</span><br/>
          Pittsburgh.
        </h1>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;">

          <!-- Contact details -->
          <div>

            <div style="margin-bottom: 48px;">
              <h2 style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 20px;">Address</h2>
              <address style="font-style: normal; font-family: var(--serif); font-size: 28px; line-height: 1.4; color: var(--ink);">
                110 Smithfield St<br/>
                Pittsburgh, PA 15222
              </address>
              <p class="body" style="margin-top: 14px;">
                One block from Market Square. Accessible via T (First Ave station), bus, or parking on Smithfield St.
              </p>
              <a
                href="https://maps.apple.com/?address=110+Smithfield+St,+Pittsburgh,+PA+15222"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-ghost"
                style="margin-top: 20px;"
              >Get Directions <span class="arr">→</span></a>
            </div>

            <div style="border-top: 1px solid var(--line); padding-top: 40px; margin-bottom: 48px;">
              <h2 style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 20px;">Contact</h2>
              <ul style="list-style: none;">
                <li style="margin-bottom: 16px;">
                  <span class="small" style="display: block; margin-bottom: 4px;">Phone</span>
                  <a href="tel:4126001000" style="font-family: var(--serif); font-size: 28px; color: var(--red);">412-600-1000</a>
                </li>
                <li>
                  <span class="small" style="display: block; margin-bottom: 4px;">Email</span>
                  <a href="mailto:eatsushikim2@gmail.com" style="font-family: var(--sans); font-size: 16px; color: var(--red); text-decoration: underline;">eatsushikim2@gmail.com</a>
                </li>
              </ul>
            </div>

            <div style="border-top: 1px solid var(--line); padding-top: 40px;">
              <h2 style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 20px;">Hours</h2>
              <table style="width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 13px; line-height: 2.4;">
                <tbody>
                  <tr style="border-bottom: 1px solid var(--line-soft);">
                    <td style="color: var(--ink-soft);">Sunday</td>
                    <td style="text-align: right; color: var(--ink);">11:30 – 20:00</td>
                  </tr>
                  <tr style="border-bottom: 1px solid var(--line-soft); opacity: 0.45;">
                    <td style="color: var(--ink-soft);">Monday</td>
                    <td style="text-align: right; color: var(--ink-mute);">Closed</td>
                  </tr>
                  <tr style="border-bottom: 1px solid var(--line-soft);">
                    <td style="color: var(--ink-soft);">Tue – Fri</td>
                    <td style="text-align: right; color: var(--ink);">11:30 – 14:30</td>
                  </tr>
                  <tr style="border-bottom: 1px solid var(--line-soft);">
                    <td style="color: var(--ink-soft);">Tue – Fri (dinner)</td>
                    <td style="text-align: right; color: var(--ink);">16:30 – 21:00</td>
                  </tr>
                  <tr>
                    <td style="color: var(--ink-soft);">Saturday</td>
                    <td style="text-align: right; color: var(--ink);">11:30 – 21:00</td>
                  </tr>
                </tbody>
              </table>
            </div>

          </div>

          <!-- Map placeholder + contact form -->
          <div>

            <!-- Map placeholder -->
            <div class="ph" style="aspect-ratio: 4/3; margin-bottom: 48px;">
              <div style="
                position: absolute; inset: 0; display: flex;
                flex-direction: column; align-items: center; justify-content: center;
                gap: 12px; color: var(--ink-mute);
              ">
                <div style="font-size: 40px;">📍</div>
                <div class="mono">110 SMITHFIELD ST · PITTSBURGH PA</div>
                <a
                  href="https://maps.apple.com/?address=110+Smithfield+St,+Pittsburgh,+PA+15222"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-ghost"
                  style="margin-top: 8px; font-size: 11px; padding: 10px 18px;"
                >Open in Maps</a>
              </div>
            </div>

            <!-- Quick message form -->
            <div style="background: var(--paper); border: 1px solid var(--line); padding: 36px;">
              <div class="mono" style="color: var(--red); margin-bottom: 20px;">SEND A MESSAGE</div>
              <form name="contact" method="POST" action="/contact/success" netlify>
                <label class="field-label" for="contact-name">Name</label>
                <input id="contact-name" name="name" type="text" class="field-input" placeholder="Your name" required />

                <label class="field-label" for="contact-email">Email</label>
                <input id="contact-email" name="email" type="email" class="field-input" placeholder="you@email.com" required />

                <label class="field-label" for="contact-msg">Message</label>
                <textarea
                  id="contact-msg"
                  name="message"
                  class="field-input"
                  placeholder="Questions, private events, catering inquiries…"
                  rows="4"
                  style="resize: vertical;"
                  required
                ></textarea>

                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
                  Send Message <span class="arr">→</span>
                </button>
              </form>
            </div>

          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  @media (max-width: 900px) {
    div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
