---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://sushikim2.com/#webpage',
  name: 'Sushi Kim 2 — Authentic Korean Food & Sushi · Downtown Pittsburgh',
  url: 'https://sushikim2.com',
  description:
    'A 30+ year Pittsburgh institution serving authentic Korean home cooking and premium Japanese sushi at 110 Smithfield St, Downtown Pittsburgh. Open Tuesday–Sunday.',
  isPartOf: { '@id': 'https://sushikim2.com/#website' },
  about: { '@id': 'https://sushikim2.com/#restaurant' },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: 'https://sushikim2.com/images/real-bulgogi.jpg',
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.hero-intro', '.story-intro'],
  },
};
---

<Layout
  title="Sushi Kim 2 — Authentic Korean Food & Sushi · Downtown Pittsburgh"
  description="A 30+ year Pittsburgh institution serving authentic Korean home cooking and premium Japanese sushi at 110 Smithfield St, Downtown Pittsburgh."
  canonicalPath=""
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  </Fragment>
  <Nav />

  <main class="page">

    <!-- ===== HERO: Editorial ===== -->
    <section class="px-pad" style="padding-top: 40px; padding-bottom: 100px;">
      <div class="max-w-site mx-auto">
        <div class="hero-grid" style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: end;">

          <div>
            <p class="eyebrow" style="margin-bottom: 28px;">
              Est. 1990 <span class="dot"></span> Pittsburgh's Korean Kitchen &amp; Sushi Bar
            </p>
            <h1 class="display">
              Authentic
              Korean <br><span class="it">food & sushi,</span><br/>
              <span class="it">in downtown Pittsburgh.</span>
            </h1>
            <p class="body-lg" style="margin-top: 32px; max-width: 46ch;">
              30+ years of slow-simmered stews, charcoal-kissed bulgogi,
              and hand-cut sashimi at 110 Smithfield — a quiet downtown room where
              Kim family recipes meet the day's catch.
            </p>
            <div style="display: flex; gap: 14px; margin-top: 40px; flex-wrap: wrap;">
              <a href="/reservations" class="btn btn-primary">
                Reserve a Table <span class="arr">→</span>
              </a>
              <a href="/menu" class="btn btn-ghost">
                View the Menu
              </a>
            </div>
            <div style="margin-top: 56px; display: flex; gap: 40px; padding-top: 32px; border-top: 1px solid var(--line);">
              <div>
                <div style="font-family: var(--serif); font-size: 36px; line-height: 1; color: var(--red); font-style: italic;">30+</div>
                <div class="small" style="margin-top: 6px; text-transform: uppercase; font-size: 10px; letter-spacing: 0.12em;">Years in Pittsburgh</div>
              </div>
              <div>
                <div style="font-family: var(--serif); font-size: 36px; line-height: 1; color: var(--red); font-style: italic;">4.8</div>
                <div class="small" style="margin-top: 6px; text-transform: uppercase; font-size: 10px; letter-spacing: 0.12em;">★ Google, 200+ reviews</div>
              </div>
              <div>
                <div style="font-family: var(--serif); font-size: 36px; line-height: 1; color: var(--red); font-style: italic;">110</div>
                <div class="small" style="margin-top: 6px; text-transform: uppercase; font-size: 10px; letter-spacing: 0.12em;">Smithfield St, Downtown</div>
              </div>
            </div>
          </div>

          <!-- Hero image stack -->
          <div style="position: relative; aspect-ratio: 3/4;">
            <div style="position: absolute; inset: 0; overflow: hidden;">
              <img src="/images/bulgogi.jpg" alt="Beef Bulgogi" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
            </div>
            <div style="
              position: absolute; bottom: -40px; left: -48px;
              width: 180px; height: 240px;
              background: var(--cream-deep);
              border: 6px solid var(--cream);
              box-shadow: 0 20px 40px rgba(42,35,32,0.18);
            "></div>
            
          </div>

        </div>
      </div>
    </section>

    <!-- ===== MARQUEE ===== -->
    <Marquee items={[
      'Authentic Korean Specialties',
      'Premium Sushi & Sashimi',
      'Since 1990',
      'Downtown Pittsburgh',
      'Korean Soul Food',
    ]} />

<section class="px-pad" style="padding-top: 60px; padding-bottom: 0px;">
      <div class="max-w-site mx-auto">

        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; flex-wrap: wrap; gap: 24px;">
          <div>
    <p>Sushi Kim 2 is a family-run Korean restaurant and sushi bar in Downtown Pittsburgh, serving bulgogi, galbi, jjigae, bibimbap, sushi, sashimi, and Korean fried chicken at 110 Smithfield St.</p>
    </div></div></div></section>

    <!-- ===== SIGNATURE DISHES ===== -->
    <section class="px-pad" style="padding-top: 0px; padding-bottom: 120px;">
      <div class="max-w-site mx-auto">

        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; flex-wrap: wrap; gap: 24px;">
          <div>
            <p class="eyebrow" style="margin-bottom: 20px;">
              House Specialties
            </p>
            <h2 class="display">
              Dishes we've <span class="it">perfected</span><br/>
              over 30+ years.
            </h2>
          </div>
          <a href="/menu" class="btn btn-ghost">Full Menu <span class="arr">→</span></a>
        </div>

        <div class="dishes-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;">

          <article>
            <div class="dish-img-wrap" style="aspect-ratio: 4/5; margin-bottom: 20px; position: relative; overflow: hidden;">
              <img src="/images/real-bulgogi.jpg" alt="Beef Bulgogi" class="dish-img" />
              <div class="mono" style="position: absolute; bottom: 16px; right: 16px; color: var(--cream); opacity: 0.9; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">01</div>
            </div>
            <h3 class="display" style="font-size: 28px; margin-bottom: 8px;">Beef Bulgogi</h3>
            <p class="body" style="font-size: 14px;">Thinly sliced beef marinated in a sweet and savory soy-based sauce, grilled to perfection with onions and scallions.</p>
          </article>

          <article>
            <div class="dish-img-wrap" style="aspect-ratio: 4/5; margin-bottom: 20px; position: relative; overflow: hidden;">
              <img src="/images/real-galbi.jpg" alt="Galbi" class="dish-img" />
              <div class="mono" style="position: absolute; bottom: 16px; right: 16px; color: var(--cream); opacity: 0.9; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">02</div>
            </div>
            <h3 class="display" style="font-size: 28px; margin-bottom: 8px;">Galbi</h3>
            <p class="body" style="font-size: 14px;">Tender beef short ribs marinated in a rich Korean BBQ sauce, grilled to a smoky, caramelized finish.</p>
          </article>

          <article>
            <div class="dish-img-wrap" style="aspect-ratio: 4/5; margin-bottom: 20px; position: relative; overflow: hidden;">
              <img src="/images/real-bibimbop.jpg" alt="Bibimbop" class="dish-img" />
              <div class="mono" style="position: absolute; bottom: 16px; right: 16px; color: var(--cream); opacity: 0.9; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">03</div>
            </div>
            <h3 class="display" style="font-size: 28px; margin-bottom: 8px;">Bibimbop</h3>
            <p class="body" style="font-size: 14px;">A vibrant Korean rice bowl topped with seasoned vegetables, beef, and a fried egg. Served with house gochujang.</p>
          </article>

          <article>
            <div class="dish-img-wrap" style="aspect-ratio: 4/5; margin-bottom: 20px; position: relative; overflow: hidden;">
              <img src="/images/real-galbi-tang.jpg" alt="Galbi Tang" class="dish-img" />
              <div class="mono" style="position: absolute; bottom: 16px; right: 16px; color: var(--cream); opacity: 0.9; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">04</div>
            </div>
            <h3 class="display" style="font-size: 28px; margin-bottom: 8px;">Galbi Tang</h3>
            <p class="body" style="font-size: 14px;">Beef short rib soup simmered with radish, onions, and glass noodles in a clear, deeply savory broth.</p>
          </article>

          <article>
            <div class="dish-img-wrap" style="aspect-ratio: 4/5; margin-bottom: 20px; position: relative; overflow: hidden;">
              <img src="/images/real-kimchi-jjigae.jpg" alt="Kimchi Jjigae" class="dish-img" />
              <div class="mono" style="position: absolute; bottom: 16px; right: 16px; color: var(--cream); opacity: 0.9; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">05</div>
            </div>
            <h3 class="display" style="font-size: 28px; margin-bottom: 8px;">Kimchi Jjigae</h3>
            <p class="body" style="font-size: 14px;">Aged kimchi stew simmered with pork, tofu, and vegetables — bold, spicy, and deeply flavorful.</p>
          </article>

          <article>
            <div class="dish-img-wrap" style="aspect-ratio: 4/5; margin-bottom: 20px; position: relative; overflow: hidden;">
              <img src="/images/real-sushi-platter.jpg" alt="Sushi Sashimi Platter" class="dish-img" />
              <div class="mono" style="position: absolute; bottom: 16px; right: 16px; color: var(--cream); opacity: 0.9; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">06</div>
            </div>
            <h3 class="display" style="font-size: 28px; margin-bottom: 8px;">Sushi Sashimi Platter</h3>
            <p class="body" style="font-size: 14px;">Chef's selection of sushi and sashimi, hand-cut daily. Served with wasabi, pickled ginger, and miso soup.</p>
          </article>

        </div>
      </div>
    </section>

    <!-- ===== STORY TEASER (dark) ===== -->
    <section style="background: var(--ink); color: var(--cream); padding: 120px var(--pad);">
      <div class="max-w-site mx-auto story-grid" style="display: grid; grid-template-columns: 1fr 1.1fr; gap: 80px; align-items: center;">

        <div style="aspect-ratio: 4/5; overflow: hidden;">
          <img src="/images/mr-kim.webp" alt="Mr. Kim" style="width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;" />
        </div>

        <div>
          <p class="eyebrow" style="color: var(--gold-soft); margin-bottom: 24px;">
            Our Story
          </p>
          <h2 class="display" style="color: var(--cream);">
            A family legacy<br/>
            in Downtown Pittsburgh.
          </h2>
          <p class="body-lg" style="color: rgba(245,239,227,0.75); margin-top: 28px; max-width: 50ch;">
            The Kim family opened their first kitchen in 1990, building a reputation
            for consistency and quality that has spanned over 35 years. Today, Sushi Kim 2
            carries that history forward at our Smithfield Street location. The city has
            changed, but our core recipes remain exactly the same.
          </p>
          <a href="/about" class="btn btn-outline-cream" style="margin-top: 36px;">
            Read Our Story <span class="arr">→</span>
          </a>
        </div>

      </div>
    </section>

    <!-- ===== REVIEWS ===== -->
    <section class="px-pad" style="padding-top: 120px; padding-bottom: 120px;">
      <div class="max-w-site mx-auto">

        <div style="text-align: center; margin-bottom: 64px;">
          <p class="eyebrow" style="margin-bottom: 20px;">What Pittsburgh Is Saying</p>
          <h2 class="display" style="max-width: 18ch; margin: 0 auto;">
            <span style="color: var(--red);">4.8 ★</span> across
            <span class="it"> 300+ reviews.</span>
          </h2>
        </div>

        <div class="reviews-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;">

          <blockquote style="padding: 40px 32px; background: var(--paper); border: 1px solid var(--line);">
            <div style="color: var(--red); font-size: 22px; margin-bottom: 16px;">★★★★★</div>
            <p style="font-family: var(--serif); font-size: 20px; line-height: 1.45; color: var(--ink); margin-bottom: 20px;">
              "The galbi here is the best I've had outside of Seoul. A downtown Pittsburgh treasure."
            </p>
            <footer class="mono" style="color: var(--ink-mute);">— Michelle L. · Google</footer>
          </blockquote>

          <blockquote style="padding: 40px 32px; background: var(--paper); border: 1px solid var(--line);">
            <div style="color: var(--red); font-size: 22px; margin-bottom: 16px;">★★★★★</div>
            <p style="font-family: var(--serif); font-size: 20px; line-height: 1.45; color: var(--ink); margin-bottom: 20px;">
              "30 years strong for a reason. The Kim family cooks with love."
            </p>
            <footer class="mono" style="color: var(--ink-mute);">— David R. · Google</footer>
          </blockquote>

          <blockquote style="padding: 40px 32px; background: var(--paper); border: 1px solid var(--line);">
            <div style="color: var(--red); font-size: 22px; margin-bottom: 16px;">★★★★★</div>
            <p style="font-family: var(--serif); font-size: 20px; line-height: 1.45; color: var(--ink); margin-bottom: 20px;">
              "Sashimi is hand-cut and perfect. Banchan is generous and thoughtful."
            </p>
            <footer class="mono" style="color: var(--ink-mute);">— Priya S. · Yelp</footer>
          </blockquote>

        </div>
      </div>
    </section>

    <!-- ===== VISIT CTA (red) ===== -->
    <section style="padding: 120px var(--pad); background: var(--red); color: var(--cream);">
      <div class="max-w-site mx-auto visit-grid" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center;">

        <div>
          <p class="eyebrow" style="color: var(--gold-soft); margin-bottom: 20px;">
            Visit Us <span class="dot" style="background: var(--gold-soft);"></span>
          </p>
          <h2 class="display" style="color: var(--cream);">
            110 Smithfield St.<br/>
            <span class="it" style="color: var(--gold-soft);">Downtown.</span>
          </h2>
          <p class="body-lg" style="color: rgba(245,239,227,0.85); margin-top: 24px;">
            A block from Market Square. Lunch service starts at 11:30.
            Dinner 4:30 to 9. Closed Mondays.
          </p>
          <div style="display: flex; gap: 14px; margin-top: 36px; flex-wrap: wrap;">
            <a href="/reservations" class="btn btn-outline-cream">
              Reserve <span class="arr">→</span>
            </a>
            <a href="tel:4126001000" class="btn btn-cream-on-red">
              Call 412-600-1000
            </a>
          </div>
        </div>

        <div style="
          background: rgba(0,0,0,0.15);
          border: 1px solid rgba(245,239,227,0.2);
          padding: 32px;
          font-family: var(--mono); font-size: 13px; line-height: 2.2;
          color: var(--cream);
        ">
          <div style="color: var(--gold-soft); font-size: 10px; letter-spacing: 0.2em; margin-bottom: 14px;">HOURS</div>
          <div>SUN &nbsp;&nbsp;&nbsp;&nbsp;11:30 — 20:00</div>
          <div style="opacity: 0.45;">MON &nbsp;&nbsp;&nbsp;CLOSED</div>
          <div>TUE–FRI &nbsp;11:30 — 14:30</div>
          <div>TUE–FRI &nbsp;16:30 — 21:00</div>
          <div>SAT &nbsp;&nbsp;&nbsp;&nbsp;11:30 — 21:00</div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .dish-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .story-grid,
    .visit-grid {
      grid-template-columns: 1fr !important;
    }
    .dishes-grid,
    .reviews-grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media (max-width: 600px) {
    .dishes-grid,
    .reviews-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
