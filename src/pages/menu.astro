// Build Menu schema from categories data — skips 'featured' to avoid duplicate items
const menuSchema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  '@id': 'https://sushikim2.com/menu#menu',
  name: 'Sushi Kim 2 Full Menu',
  description:
    'Complete menu of Sushi Kim 2, featuring authentic Korean home cooking and fresh Japanese sushi in Downtown Pittsburgh.',
  url: 'https://sushikim2.com/menu',
  inLanguage: 'en',
  hasMenuSection: categories
    .filter(cat => cat.id !== 'featured')
    .map(cat => ({
      '@type': 'MenuSection',
      name: cat.label,
      description: cat.blurb,
      hasMenuItem: cat.items.map(item => {
        const fullName = [item.code, item.en, item.subtitle].filter(Boolean).join(' — ');
        const entry: Record<string, unknown> = {
          '@type': 'MenuItem',
          name: fullName,
        };
        if (item.description) entry.description = item.description;
        if (item.price) {
          entry.offers = {
            '@type': 'Offer',
            price: item.price.replace('$', ''),
            priceCurrency: 'USD',
            availability: item.outOfStock
              ? 'https://schema.org/OutOfStock'
              : 'https://schema.org/InStock',
          };
        }
        if (item.tags.includes('vegetarian')) {
          entry.suitableForDiet = 'https://schema.org/VegetarianDiet';
        }
        return entry;
      }),
    })),
};

