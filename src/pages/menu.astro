      },
    },
    {
      '@type': 'Question',
      name: 'Does Sushi Kim 2 accommodate gluten-free diners?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Some dishes at Sushi Kim 2 are naturally gluten-free, but soy sauce is used across the kitchen. Let your server know about any allergies and they will do their best to accommodate you safely.',
      },
    },
  ],
};
---

<Layout
  title="Menu — Sushi Kim 2 · Downtown Pittsburgh"
  description="Full menu with prices — Korean home cooking, fresh sushi, and specialty rolls at Sushi Kim 2, 110 Smithfield St Downtown Pittsburgh."
  canonicalPath="/menu"
  ogImage="/images/real-sushi-platter.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(menuPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(menuSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(menuFaqSchema)} />
  </Fragment>
  <Nav />

  <main class="page">

    <!-- Header -->
    <section class="px-pad" style="padding-top: 60px; padding-bottom: 40px;">
      <div class="max-w-site mx-auto">
        <p class="eyebrow" style="margin-bottom: 20px;">
          The Menu
        </p>
        <div class="menu-header-grid">
          <h1 class="display">
            Korean soul food,<br/>
            <span class="it">hand-cut sushi,</span><br/>
            <span class="it">— with care.</span>
          </h1>
          <div>
            <p class="body-lg" style="margin-bottom: 24px;">
              Dishes marked
              <span style="color: var(--red); font-family: var(--mono); font-size: 11px; padding: 2px 6px; border: 1px solid var(--red);">SIGNATURE</span>
              are the ones we've been serving since we opened in 1990.
            </p>
            <div style="display: flex; gap: 16px; font-family: var(--mono); font-size: 11px; color: var(--ink-mute); flex-wrap: wrap;">
              <span style="display: inline-flex; align-items: center; gap: 6px;">
                <span style="width: 8px; height: 8px; background: var(--red); border-radius: 50%; display: inline-block; flex-shrink: 0;"></span> Spicy
              </span>
              <span style="display: inline-flex; align-items: center; gap: 6px;">
                <span style="width: 8px; height: 8px; background: var(--gold); border-radius: 50%; display: inline-block; flex-shrink: 0;"></span> Vegetarian
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sticky tabs + search -->
    <div id="menu-tabs-bar" style="
      position: sticky; top: 72px; z-index: 20;
      background: rgba(245,239,227,0.96);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 14px var(--pad);
      margin-top: 32px;
    ">
      <div class="tabs-bar-inner max-w-site mx-auto">
        <div class="search-wrap">
          <span style="font-size: 14px; color: var(--ink-mute);">⌕</span>
          <input
            id="menu-search"
            type="search"
            placeholder="Search…"
            style="border: none; background: transparent; outline: none; font-family: var(--sans); font-size: 13px; flex: 1; color: var(--ink); min-width: 0;"
            aria-label="Search menu items"
          />
        </div>
        <div class="tabs-scroll-wrap" id="tabs-scroll-wrap">
          <div id="tab-btns">
            {categories.map((cat, i) => (
              <button class="tab-btn" data-tab={cat.id} aria-selected={i === 0 ? 'true' : 'false'}>
                {cat.label}
                <span class="tab-count">{String(cat.items.length).padStart(2, '0')}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Menu categories -->
    <section class="px-pad" style="padding-top: 60px; padding-bottom: 80px;">
      <div class="max-w-site mx-auto">

        {categories.map((cat, i) => (
          <div class="menu-category" data-category={cat.id} style={i > 0 ? 'display:none' : ''}>
            <div class="menu-layout">

              <!-- Sidebar -->
              <aside class="menu-sidebar">
                <div class="mono" style="color: var(--red); margin-bottom: 12px;">
                  {String(i + 1).padStart(2, '0')} / {String(categories.length).padStart(2, '0')}
                </div>
                <h2 class="display" style="font-size: clamp(34px, 4vw, 52px); margin-bottom: 14px; line-height: 1.05;">
                  {cat.label}
                </h2>
                <p class="body" style="max-width: 30ch;">{cat.blurb}</p>
              </aside>

              <!-- Items -->
              <div class="menu-items-col">
                {cat.items.map(item => (
                  <article
                    class="menu-item"
                    data-name={(item.en + ' ' + (item.subtitle ?? '') + ' ' + (item.code ?? '') + ' ' + (item.description ?? '')).toLowerCase()}
                    style={item.outOfStock ? 'opacity: 0.45;' : ''}
                  >
                    <div style="display: flex; align-items: baseline; gap: 16px;">
                      <div style="display: flex; align-items: flex-start; gap: 8px; flex-wrap: wrap; flex: 1;">
                        {item.code && (
                          <span class="item-code">{item.code}</span>
                        )}
                        <h3 class="item-name" style={item.outOfStock ? 'text-decoration: line-through;' : ''}>
                          {item.en}
                        </h3>
                        {item.subtitle && (
                          <span class="item-subtitle">{item.subtitle}</span>
                        )}
                        {item.outOfStock && (
                          <span class="item-oos">Out of stock</span>
                        )}
                        {item.tags.includes('signature') && (
                          <span class="tag-signature">Signature</span>
                        )}
                        {item.tags.includes('spicy') && (
                          <span class="tag-dot" style="background: var(--red);" title="Spicy"></span>
                        )}
                        {item.tags.includes('vegetarian') && (
                          <span class="tag-dot" style="background: var(--gold);" title="Vegetarian"></span>
                        )}
                      </div>
                      {item.price && (
                        <span class="item-price">{item.price}</span>
                      )}
                    </div>
                    {item.description && (
                      <p class="item-desc">{item.description}</p>
                    )}
                  </article>
                ))}
                <p class="no-results" style="display: none; padding: 40px 0; font-family: var(--serif); font-style: italic; color: var(--ink-mute);">
                  No items found for that search.
                </p>
              </div>

            </div>
          </div>
        ))}

      </div>
    </section>

    <!-- CTA -->
    <section style="border-top: 1px solid var(--line); padding: 80px var(--pad); background: var(--cream-deep);">
      <div class="max-w-site mx-auto" style="text-align: center;">
        <p class="eyebrow" style="margin-bottom: 20px;">Ready to eat?</p>
        <h2 class="display" style="margin-bottom: 32px;">
          Order online, or <span class="it">reserve a table.</span>
        </h2>
        <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
          <a href="https://order.toasttab.com/online/sushi-kim-2" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Order Online <span class="arr">→</span>
          </a>
          <a href="/reservations" class="btn btn-ghost">Reserve a Table</a>
        </div>
      </div>
    </section>

    <!-- Menu FAQ -->
    <section class="px-pad" style="padding-top: 80px; padding-bottom: 100px; border-top: 1px solid var(--line);">
      <div class="max-w-site mx-auto">

        <p class="eyebrow" style="margin-bottom: 20px;">Menu FAQ</p>
        <h2 class="display" style="margin-bottom: 60px; max-width: 22ch;">
          Questions about <span class="it">the menu.</span>
        </h2>

        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-q">Is this a Korean restaurant or a Japanese restaurant?</div>
            <div class="faq-a">Both. We've been cooking Korean food since 1990 — bibimbap, bulgogi, galbi, jjigae, doenjang jjigae — and our sushi and sashimi have been on the menu for decades. Most people come in for one side and end up ordering from both.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">Can I order sushi and Korean food at the same table?</div>
            <div class="faq-a">Absolutely — that's kind of our thing. Many of our regulars mix a sushi platter with a bowl of galbi tang or a plate of bulgogi. Everything comes out together.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">Is the KFC on the menu actually Korean fried chicken?</div>
            <div class="faq-a">Yes. Double-fried until it's shatteringly crisp, then tossed in your choice of sauce. It's one of our most-ordered dishes, and for good reason.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">What are your most popular dishes?</div>
            <div class="faq-a">Beef bulgogi, galbi, bibimbap, galbi tang, and the chef's sushi platter are the dishes we've been sending out every single day for years. If you're new, start there.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">Do you have vegetarian options?</div>
            <div class="faq-a">Yes. Bibimbap can be made vegetarian, doenjang jjigae is available without meat, and we have several veggie-forward banchan sides. Let your server know and we'll point you in the right direction.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">How spicy is the food?</div>
            <div class="faq-a">Most dishes aren't aggressively hot by default — we cook for a wide range of people. Kimchi jjigae has a kick. If you want things hotter or milder, just ask.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">Do you serve lunch?</div>
            <div class="faq-a">Yes — Tuesday through Saturday, 11:30 to 14:30. The full menu is available at lunch, not a reduced version. Sunday is all-day service from 11:30 to 20:00.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">Can I order online?</div>
            <div class="faq-a">Yes. We use Toast for online ordering — the link is at the top of this page and in the footer. You can order pickup or call ahead for takeout as well.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">What's the difference between the sashimi and the sushi platter?</div>
            <div class="faq-a">Sashimi is sliced fish only — no rice. The sushi platter includes both nigiri (fish on rice) and rolls. The chef's platter is our flagship: a selection chosen daily based on what came in fresh.</div>
          </div>

          <div class="faq-item">
            <div class="faq-q">Do you accommodate gluten-free diners?</div>
            <div class="faq-a">Some of our dishes are naturally gluten-free, but soy sauce is used across the kitchen. Please let your server know about any allergies and we'll do our best to accommodate you safely.</div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const menuCategories = document.querySelectorAll<HTMLElement>('.menu-category');
  const searchInput = document.getElementById('menu-search') as HTMLInputElement | null;

  function activateTab(id: string) {
    tabBtns.forEach(btn => {
      btn.setAttribute('aria-selected', btn.dataset.tab === id ? 'true' : 'false');
    });
    menuCategories.forEach(cat => {
      cat.style.display = cat.dataset.category === id ? '' : 'none';
    });
    if (searchInput) {
      searchInput.value = '';
      filterItems('');
    }
  }

  function filterItems(query: string) {
    const q = query.toLowerCase().trim();
    const activeCategory = Array.from(menuCategories).find(
      cat => cat.style.display !== 'none' && !cat.style.display.includes('none')
    ) ?? menuCategories[0];

    const items = activeCategory.querySelectorAll<HTMLElement>('.menu-item');
    const noResults = activeCategory.querySelector<HTMLElement>('.no-results');
    let visible = 0;

    items.forEach(item => {
      const name = item.dataset.name || '';
      const match = !q || name.includes(q);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.tab;
      if (id) activateTab(id);
    });
  });

  searchInput?.addEventListener('input', () => filterItems(searchInput.value));

  /* Scroll indicators */
  const tabsScrollWrap = document.getElementById('tabs-scroll-wrap');
  const tabBtnsEl = document.getElementById('tab-btns');

  function updateIndicators() {
    if (!tabBtnsEl || !tabsScrollWrap) return;
    const { scrollLeft, scrollWidth, clientWidth } = tabBtnsEl;
    tabsScrollWrap.classList.toggle('show-left', scrollLeft > 4);
    tabsScrollWrap.classList.toggle('show-right', scrollLeft < scrollWidth - clientWidth - 4);
  }

  tabBtnsEl?.addEventListener('scroll', updateIndicators, { passive: true });
  window.addEventListener('resize', updateIndicators);
  updateIndicators();
</script>

<style>
  .menu-header-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 60px;
    align-items: end;
  }

  /* Tab bar layout */
  .tabs-bar-inner {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--line);
    padding: 8px 14px;
    background: var(--paper);
    min-width: 180px;
    flex-shrink: 0;
  }

  .tabs-scroll-wrap {
    flex: 1;
    min-width: 0;
    position: relative;
  }
  .tabs-scroll-wrap::before,
  .tabs-scroll-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 48px;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .tabs-scroll-wrap::before {
    left: 0;
    background: linear-gradient(to right, rgba(245,239,227,0.96) 40%, transparent);
  }
  .tabs-scroll-wrap::after {
    right: 0;
    background: linear-gradient(to left, rgba(245,239,227,0.96) 40%, transparent);
  }
  .tabs-scroll-wrap.show-left::before { opacity: 1; }
  .tabs-scroll-wrap.show-right::after { opacity: 1; }

  #tab-btns {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }
  #tab-btns::-webkit-scrollbar { display: none; }

  @media (max-width: 768px) {
    .tabs-bar-inner { flex-wrap: wrap; gap: 10px; }
    .search-wrap { width: 100%; order: 0; min-width: 0; }
    .tabs-scroll-wrap { width: 100%; order: 1; }
  }

  .tab-btn {
    padding: 9px 15px;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    white-space: nowrap;
    background: transparent;
    color: var(--ink);
    border: 1px solid transparent;
    transition: all 0.2s;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .tab-btn[aria-selected="true"] {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }
  .tab-btn:hover:not([aria-selected="true"]) { border-color: var(--line); }
  .tab-count { font-family: var(--mono); font-size: 10px; opacity: 0.5; }

  /* Menu grid */
  .menu-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 60px;
  }
  .menu-sidebar {
    position: sticky;
    top: 180px;
    align-self: start;
  }
  .menu-items-col { min-width: 0; }

  /* Item rows */
  .menu-item {
    padding: 20px 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .menu-item:first-child { border-top: 1px solid var(--line-soft); }

  .item-code {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.08em;
    padding-top: 6px;
    flex-shrink: 0;
  }
  .item-name {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
  }
  .item-subtitle {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-mute);
    padding-top: 5px;
  }
  .item-desc {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-top: 6px;
    max-width: 58ch;
  }
  .item-oos {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    border: 1px solid var(--line);
    padding: 2px 6px;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .tag-signature {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--red);
    border: 1px solid var(--red);
    padding: 2px 6px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
    margin-top: 4px;
  }
  .tag-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
    margin-top: 8px;
  }
  .item-price {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--gold);
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .menu-header-grid { grid-template-columns: 1fr; }
    .menu-layout { grid-template-columns: 1fr; }
    .menu-sidebar { position: static; margin-bottom: 32px; }
  }

  /* FAQ */
  .faq-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
  }
  .faq-item {
    padding: 32px 0;
    border-bottom: 1px solid var(--line);
  }
  .faq-item:nth-child(odd) {
    padding-right: 48px;
    border-right: 1px solid var(--line);
  }
  .faq-item:nth-child(even) {
    padding-left: 48px;
  }
  .faq-q {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .faq-a {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
  }
  @media (max-width: 700px) {
    .faq-list {
      grid-template-columns: 1fr;
    }
    .faq-item:nth-child(odd) {
      padding-right: 0;
      border-right: none;
    }
    .faq-item:nth-child(even) {
      padding-left: 0;
    }
  }
</style>
